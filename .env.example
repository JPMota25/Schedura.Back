# Copy this file to .env and adjust values for your environment.
# Optional: create .env.Development / .env.Production to override specific keys by environment.
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=SlotMeDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;

# JWT — gerar secret seguro com:
#   openssl rand -base64 48
# Mínimo recomendado: 32 bytes (256 bits) para HS256
Jwt__Secret=SUBSTITUA_POR_UM_SECRET_GERADO_COM_openssl_rand_-base64_48
